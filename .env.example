# ─── CORE SYSTEM ─────────────────────────────────────────────────────────────
# LLM Provider: 'gemini' or 'openai'
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Options (Required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o

# Model Configuration Options (Optional overrides)
# GEMINI_MODEL_NAME=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# LLM_TEMPERATURE=0.7

# Pinecone Vector DB for Document Grounding & RBAC
# (Make sure index dimensions accurately match your LLM embedding space: gemini-001 = 768 / text-embedding-3-small = 1536)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=heynova

# Pinecone Serverless Index Location (used for auto-provisioning on backend startup)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Live Web Search (Optional but recommended)
TAVILY_API_KEY=your_tavily_api_key_here

# Redis Memory (Required for Session, Global Learning Method & Rate Limiter Pools)
REDIS_URL=redis://localhost:6379/0

# Supabase Database (Required for user auth, profiles, and conversation persistence)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# CORS allowlist for the backend (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Legacy auth fallback (X-User-ID header). MUST be false in production.
ALLOW_LEGACY_AUTH=false

# ─── SECURITY & AUTH ─────────────────────────────────────────────────────────
# JWT Authentication Secret. Generate a strong random hash for production:
# e.g., run `python -c "import secrets; print(secrets.token_urlsafe(32))"`
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_sovereign_default_key_2026

# If true, backend refuses to start when JWT_SECRET is still the default.
ENFORCE_STRONG_JWT_SECRET=true

# ─── FRONTEND BUILD-TIME VARS (Vite) ─────────────────────────────────────────
# Set these in your frontend environment when building/deploying the UI.
# VITE_API_BASE=http://localhost:8000
# VITE_ALLOW_LEGACY_AUTH=false

# Active JWT Session TTL in Hours
JWT_EXPIRY_HOURS=24

# Comma-separated list of recognized Admin User IDs allowed to curate Teacher Portal via Legacy Headers fallback.
ADMIN_IDS=sovereign_admin_1,principal_smith

# ─── OPERATIONAL LIMITS (TTL) ────────────────────────────────────────────────
# How long ephemeral conversation arrays + Heavy Two-Tier Parent Chunks stay in Redis (default: 30 days in seconds)
CONVERSATION_TTL_SECONDS=2592000

# How long a student's Global Learning Method persists structurally (default: 365 days / 31536000s)
LEARNING_METHOD_TTL_SECONDS=31536000

# How long enrollment links persist (default: 0 = no expiry)
ENROLLMENT_TTL_SECONDS=0

# How long teacher-uploaded parent chunks persist (default: 365 days / 31536000s). 0 = no expiry.
TEACHER_CONTENT_TTL_SECONDS=31536000

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
# (Limits based on unique local machine IPs, securely enforced centrally by Redis)
RATE_LIMIT_CHAT="20/minute"
RATE_LIMIT_GENERATE="10/minute"
RATE_LIMIT_UPLOAD="5/minute"
RATE_LIMIT_AUTH="10/minute"

# Agent execution logging (enable only for debugging)
AGENT_VERBOSE=false
